# =============================================
# .env.example — template configurazione progetto
# Copia in .env e compila con i tuoi valori.
# MAI committare il .env reale (è in .gitignore).
# =============================================

# --- Pixabay (musica + SFX, free, no attribuzione) ---
# Ottieni la tua key gratis: https://pixabay.com/api/docs/
PIXABAY_API_KEY=

# --- Freesound (SFX fallback, free, filtri CC0/CC-BY) ---
# Ottieni la tua key gratis: https://freesound.org/apiv2/apply/
FREESOUND_API_KEY=

# --- Configurazione progetto ---
PROJECT_NAME=dalla-scrivania-allalgoritmo
OUTPUT_DIR=./deck/assets
LOG_LEVEL=INFO

# --- Note ---
# Veo 3.1 Fast: non serve API key, lo usi MANUALMENTE da Gemini app
#   con il tuo piano Google AI Pro (49€/mese, già pagato).
# Nano Banana Pro: stesso, manuale da Gemini app.
