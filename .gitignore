# =============================================
# .gitignore — file ed esclusioni
# =============================================

# --- Secrets (mai committare) ---
.env
.env.local
.env.*.local
*.json.bak
service-account.json
**/service-account*.json
**/credentials*.json

# --- Assets generati (grandi, rigenerabili) ---
deck/assets/videos/
deck/assets/audio/
deck/assets/images/*.png
deck/assets/images/*.jpg
!deck/assets/images/logo.svg
!deck/assets/images/.gitkeep

# Solo gli SVG vettoriali dei loghi/icone vanno in repo
# I PNG/JPG generati no — troppo grandi

# --- Output finali ---
outputs/*.mp4
outputs/*.mov
outputs/*.webm
!outputs/.gitkeep

# --- Node ---
node_modules/
npm-debug.log
yarn-error.log
package-lock.json
yarn.lock

# --- Python ---
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
venv/
env/
.venv/
*.egg-info/
.pytest_cache/

# --- OS ---
.DS_Store
Thumbs.db
*.swp
*.swo

# --- IDE ---
.vscode/
.idea/
*.sublime-*

# --- Log e cache locali ---
logs/
*.log
.cache/
tmp/
temp/

# --- Claude Code internals (eccetto le nostre skill) ---
.claude/cache/
.claude/sessions/
# Le skill custom in .claude/skills/ DEVONO essere in repo
# Gli agent in .claude/agents/ DEVONO essere in repo
# I file di plugin .claude/plugins/PLUGIN_INSTALL.md DEVE essere in repo

# --- Vercel ---
.vercel/
